PAYMENT_JWT_SECRET= # 32+ chars recommended
PAYPAL_CLIENT_SECRET=

# --- Non-secrets ---
PAYMENT_MODE=auto
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
