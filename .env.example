# Copy this file to .env.local for local-only values.
# Never put real secrets in .env.example or any other tracked file.

# --- Secrets (do not commit real values) ---
KIE_API_KEY=
PAYMENT_JWT_SECRET= # 32+ chars recommended
PAYPAL_CLIENT_SECRET=
OPENROUTER_API_KEY=

# --- Non-secrets ---
PAYMENT_MODE=auto
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Nano Banana Pro cost control (allowed: 1K or 2K; 4K is blocked)
NANO_BANANA_RESOLUTION=2K

# Optional overrides
KIE_API_BASE_URL=https://api.kie.ai
KIE_UPLOAD_BASE_URL=https://kieai.redpandaai.co
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=https://dreamydecor.ai
